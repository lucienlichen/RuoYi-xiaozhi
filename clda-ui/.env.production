# 页面标题
VITE_APP_TITLE = 起重装备全生命周期数据AI智能体

# 生产环境配置
VITE_APP_ENV = 'production'

# 起重装备全生命周期数据AI智能体/生产环境
VITE_APP_BASE_API = '/prod-api'

# WebSocket 地址（留空则自动使用 wss://{hostname}/clda/v1 经 nginx 反代）
# 如需指定可设为: VITE_APP_WS_URL = wss://your-domain.com/clda/v1
# VITE_APP_WS_URL =

# 是否在打包时开启压缩，支持 gzip 和 brotli
VITE_BUILD_COMPRESS = gzip
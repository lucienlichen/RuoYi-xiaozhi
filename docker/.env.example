# ========================================
# CLDA Docker 部署环境变量
# ========================================
# 使用方法:
#   1. 复制本文件为 .env: cp .env.example .env
#   2. 修改下方所有 CHANGE_ME 值
#   3. 启动: docker compose up -d
#
# 注意: .env 文件已被 .gitignore 忽略，不会提交到代码仓库

# ==================== 数据库 ====================
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_password_here
MYSQL_DATABASE=clda
MYSQL_USER=root

# ==================== Redis ====================
# REDIS_PASSWORD=          # 如需密码保护，取消注释并设置

# ==================== MinIO 对象存储 ====================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_minio_secret
MINIO_BUCKET=clda

# ==================== JWT 令牌 ====================
# 必须设置为随机强密钥（至少32位）
# 可用命令生成: openssl rand -base64 48
TOKEN_SECRET=CHANGE_ME_random_jwt_secret_at_least_32_chars

# ==================== 设备 WebSocket 地址 ====================
# OTA 激活响应返回给 ESP32 设备的 WebSocket 地址
# 必须设置为设备可达的公网地址（如使用 HTTPS，设为 wss://）
CHAT_WS_URL=wss://your-domain.com/clda/v1

# ==================== CORS 跨域 ====================
# 生产环境设置为实际前端域名（多个用逗号分隔）
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ==================== Druid 监控台 ====================
DRUID_STAT_USERNAME=clda
DRUID_STAT_PASSWORD=CHANGE_ME_druid_password

# ==================== LLM 配置（Admin 端数据处理） ====================
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.openai.com
LLM_MODEL=gpt-4o-mini

# ==================== LLM 配置（Chat 语音对话） ====================
CHAT_LLM_API_KEY=your-chat-llm-api-key
CHAT_LLM_BASE_URL=https://open.bigmodel.cn/api/paas
CHAT_LLM_MODEL=glm-4-flash
CHAT_LLM_PATH=/v4/chat/completions

# ==================== TTS 火山引擎 ====================
VOLC_TTS_APPID=your-volc-tts-appid
VOLC_TTS_TOKEN=your-volc-tts-access-token
